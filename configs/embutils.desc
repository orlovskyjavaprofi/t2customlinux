[I] Stripped down utilities for embedded use

[T] Stripped down utilities for embedded use including date, mount, umount,
[T] printenv, tar, tee, dmesg, df, sync, mv, dd, ls, tr, cmp, cat and so
[T] on.

[U] http://www.fefe.de/embutils/

[A] Felix von Leitner <fefe@fefe.de>
[M] RenÃ© Rebe <rene@exactco.de>

[F] CROSS DIETLIBC NO-LTO

[C] base/system

[L] GPL
[V] 0.19
[P] X -----5---9 102.040

[D] 3434698388 embutils-0.19.tar.bz2 http://dl.fefe.de/

pkginstalled coreutils && [ $prefix_auto = 1 ] && bindir=/$prefix/embutils

var_append CC_WRAPPER_APPEND ' ' -std=gnu17

# non-dietlibc, e.g. glibc/musl system libc?
[ "$SDECFG_DIETLIBC_embutils" = 1 ] ||
	var_append patchfiles ' ' $confdir/not-dietlibc.diff

hook_add premake 5 "mkdir -p bin"
hook_add inmake 5 'mkdir -p $root$bindir'

# we control some stuff ourselves
var_append makeopt ' ' 'DIET= OBJDIR=bin'
var_append makeinstopt ' ' 'DIET= OBJDIR=bin'

# Add these to your build flags in the .desc file
var_append CFLAGS ' ' "-Wno-error=strict-prototypes -std=gnu89 -fpermissive"

var_append makeopt ' ' "V=1"

# 1. Error prototype fix
hook_add premake 1 'sed -i "s/void error() __attribute__((noreturn));/void error(char *message) __attribute__((noreturn));/" chroot.c'

# 2. Buffer.c function pointer fix
hook_add premake 2 'sed -i "s/int (\*op)(\s*);/int (\*op)(int, char *, size_t);/" buffer.c'

# 3. ln.c main fix
hook_add premake 3 'sed -i "s/main(int argc,char \*argv\[\])/int main(int argc,char \*argv\[\])/" ln.c'

# 4. mv.c sendfile header
hook_add premake 3 'sed -i "1i #include <sys/sendfile.h>" mv.c'

# 5. Global header injection for missing string.h, stdio.h, etc.
# This loop replaces all your manual single-file header additions
hook_add premake 5 'for f in *.c; do \
    grep -q "strlen" "$f" && ! grep -q "string.h" "$f" && { echo "Patching $f"; sed -i "1i #include <string.h>" "$f"; }; \
    grep -q "sendfile" "$f" && ! grep -q "sys/sendfile.h" "$f" && { echo "Patching $f"; sed -i "1i #include <sys/sendfile.h>" "$f"; }; \
    grep -q "wait" "$f" && ! grep -q "sys/wait.h" "$f" && { echo "Patching $f"; sed -i "1i #include <sys/wait.h>" "$f"; }; \
done'