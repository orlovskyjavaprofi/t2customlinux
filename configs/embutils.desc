[L] GPL
[V] 0.19
[P] X -----5---9 102.040

[D] 3434698388 embutils-0.19.tar.bz2 http://dl.fefe.de/

# 1. Variables
[ -z "$prefix" ] && prefix="/usr"
bindir="${prefix}/embutils"

# 2. Makefile and Source Patching
hook_add premake 5 '
    # Fix Makefile flags: Change entire line
    sed -i "/^FLAGS=/c FLAGS=-D_GNU_SOURCE -Wno-implicit-function-declaration -Wno-implicit-int -Wno-error" Makefile

    # Fix build directory creation: Delete target line, then append new line
    sed -i "/test -d \$(OBJDIR) || mkdir/d" Makefile
    sed -i "/mkdir/a mkdir -p \$(OBJDIR)" Makefile

    # Fix write12.h
    for h in write12.h; do
        [ -f "$h" ] || continue
        grep -qF "<unistd.h>" "$h" || sed -i "1i #include <unistd.h>" "$h"
        grep -qF "<string.h>" "$h" || sed -i "1i #include <string.h>" "$h"
    done

    # Per-source fixes
    for f in *.c; do
        [ -f "$f" ] || continue

        # utsname compatibility: Delete line containing pattern, append fixed line
        # Note: This replaces the line entirely; ensure the line contains only the pattern
        sed -i "/\.domainname/d" "$f"
        sed -i "/.__domainname/!a .__domainname" "$f"

        # environ declaration
        if grep -qw environ "$f" && ! grep -qF "extern char **environ" "$f"; then
            sed -i "1i extern char **environ;" "$f"
        fi
        
        # Missing headers: Using "i" (insert) which is safe and avoids "s"
        grep -qEw "write|read|close|chdir|fchdir|rmdir|unlink|getpid|fork" "$f" && ! grep -qF "<unistd.h>" "$f" && sed -i "1i #include <unistd.h>" "$f"
        grep -qEw "strlen|strcmp|strcpy|strcat|strncmp|strdup|memcpy|memset" "$f" && ! grep -qF "<string.h>" "$f" && sed -i "1i #include <string.h>" "$f"
        grep -qEw "malloc|calloc|realloc|free|exit|atoi|getenv|strtol" "$f" && ! grep -qF "<stdlib.h>" "$f" && sed -i "1i #include <stdlib.h>" "$f"
        grep -qEw "major|minor|makedev" "$f" && ! grep -qF "<sys/sysmacros.h>" "$f" && sed -i "1i #include <sys/sysmacros.h>" "$f"
    done
'

# 3. MD5 stub: Change entire line
hook_add premake 7 '
    sed -i "/#include <md5\.h>/c // #include <md5.h>" *.c
'

# 4. Build and install path fixes
hook_add premake 8 '
    sed -i "/prefix=\/opt\/diet/c prefix=/usr" Makefile
    sed -i "/\$(DESTDIR)\$(prefix)\/bin/c \$(DESTDIR)'"$bindir"'" Makefile
'

var_append makeopt       ' ' 'DIET= OBJDIR=bin'
var_append makeinstopt ' ' 'DIET= OBJDIR=bin prefix=/usr DESTDIR=$root'