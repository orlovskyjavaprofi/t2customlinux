# --- Cleaned embutils.desc ---

# 1. Define variables upfront
[ -z "$prefix" ] && prefix="/usr"
bindir="${prefix}/lib/embutils"

# 2. Compiler flags
var_append CFLAGS ' ' '-D_GNU_SOURCE -D_POSIX_C_SOURCE=200809L'
var_append CC_WRAPPER_APPEND ' ' -std=gnu17

# 3. Handle non-dietlibc
[ "$SDECFG_DIETLIBC_embutils" = 1 ] || var_append patchfiles ' ' $confdir/not-dietlibc.diff

# 4. Hooks
hook_add premake 5 "mkdir -p bin"
hook_add premake 6 "sed -i '1i #include <unistd.h>\nextern char **environ;' env.c"
hook_add premake 7 "sed -i 's/domainname/__domainname/g' domainname.c"
hook_add inmake 5 'mkdir -p $root$bindir'

# 5. Build options
var_append makeopt ' ' 'DIET= OBJDIR=bin'
var_append makeinstopt ' ' 'DIET= OBJDIR=bin'

# 6. Installation wrapper
var_append INSTALL_WRAPPER_FILTER '|' "sed -e 's,$prefix/bin/,$bindir/,'"