[P] X -----5---9 102.040

[D] 3434698388 embutils-0.19.tar.bz2 http://dl.fefe.de/

# 1. Variables
[ -z "$prefix" ] && prefix="/usr"
bindir="${prefix}/embutils"

# 2. Makefile patches
hook_add premake 5 '
    # GCC 16 compat — FLAGS is the Makefile extension point
    sed -i "s|^FLAGS=$|FLAGS=-D_GNU_SOURCE -Wno-implicit-function-declaration -Wno-implicit-int -Wno-error|" Makefile

    # Fix parallel mkdir race condition
    sed -i "s|test -d \$(OBJDIR) || mkdir|mkdir -p|g" Makefile

    # Fix write12.h — write() and strlen() need headers
    grep -qF "<unistd.h>" write12.h || sed -i "1i #include <unistd.h>" write12.h
    grep -qF "<string.h>"  write12.h || sed -i "1i #include <string.h>"  write12.h

    # Per .c file fixes
    for f in *.c; do
        [ -f "$f" ] || continue

        # struct utsname GNU extension
        sed -i "s/\.domainname/.__domainname/g" "$f"

        # environ declaration
        if grep -qw "environ" "$f" && ! grep -qF "extern char **environ" "$f"; then
            sed -i "1i extern char **environ;" "$f"
        fi

        # unistd.h
        if grep -qEw "write|read|close|chdir|fchdir|rmdir|unlink|getpid|fork" "$f" && \
           ! grep -qF "<unistd.h>" "$f"; then
            sed -i "1i #include <unistd.h>" "$f"
        fi

        # string.h
        if grep -qEw "strlen|strcmp|strcpy|strcat|strncmp|strdup|memcpy|memset" "$f" && \
           ! grep -qF "<string.h>" "$f"; then
            sed -i "1i #include <string.h>" "$f"
        fi

        # stdlib.h
        if grep -qEw "malloc|calloc|realloc|free|exit|atoi|getenv|strtol" "$f" && \
           ! grep -qF "<stdlib.h>" "$f"; then
            sed -i "1i #include <stdlib.h>" "$f"
        fi

        # sys/sysmacros.h
        if grep -qEw "major|minor|makedev" "$f" && \
           ! grep -qF "<sys/sysmacros.h>" "$f"; then
            sed -i "1i #include <sys/sysmacros.h>" "$f"
        fi
    done
'

# 3. MD5 stub
hook_add premake 7 '
    for f in *.c; do
        [ -f "$f" ] || continue
        sed -i "s|#include <md5\.h>|// #include <md5.h>|g" "$f"
    done
'

# 4. Build
hook_add inmake 5 "mkdir -p \$root\$bindir"
var_append makeopt     ' ' 'DIET= OBJDIR=bin'
var_append makeinstopt ' ' 'DIET= OBJDIR=bin'

hook_add premake 8 '
    sed -i "s|prefix=/opt/diet|prefix=/usr|g" Makefile
    sed -i "s|\$(DESTDIR)\$(prefix)/bin|\$(DESTDIR)$bindir|g" Makefile
'
var_append makeinstopt ' ' "prefix=/usr DESTDIR=$root"