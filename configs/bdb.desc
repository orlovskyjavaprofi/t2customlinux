[I] Sleepycat Berkley DB Version

[T] Berkley DB is a set of DB libraries for many types of
[T] standard DB table systems. It has a C and C++ interface.

[U] https://www.oracle.com/technology/products/berkeley-db/

[A] Sleepycat
[M] RenÃ© Rebe <rene@exactco.de>

[F] CROSS FPIC

[C] base/library
[L] BSD
[V] 5.3.28
[P] X -----5---9 107.000

[D] 9a5bc425a3702a07cb3382aca345a75d07d9d398cc6d8dde02b59fe1 db-5.3.28.tar.gz https://download.oracle.com/berkeley-db/

# 1. Force modern locking to bypass the FCNTL error
var_append confopt ' ' "--with-mutex=POSIX/pthreads --enable-compat185 --enable-cxx"

# 2. Compiler flags: Silence legacy warnings & ensure header visibility
var_append CFLAGS ' ' "-Wno-error=old-style-definition -I$srcdir"

# 3. Libtool fix
local fixed_libtool="/usr/bin/libtool --tag=CXX"
var_append makeopt ' ' "LIBTOOL=\"$fixed_libtool\" -j1"

# 4. Correctly timed header copy (Must happen after configure, before make)
hook_add premake 1 "cp db_config.h lang/db185/ && cp db_config.h src/btree/ && cp db_config.h src/mutex/"

if [[ $pkg != *-java ]]; then
    hook_add postmake 3 "ln -sfv db${ver:0:1}/db.h ${root}$includedir/../db.h"
    hook_add postmake 3 "ln -sfv db${ver:0:1}/db_185.h ${root}$includedir/../db_185.h"
fi

var_append confopt ' ' "--build=$(gcc -dumpmachine) --host=$(gcc -dumpmachine)"

# Update CFLAGS to include the root and the potential 'build' subdirectories
# This ensures that #include "db_config.h" will be resolved correctly
var_append CFLAGS ' ' "-I. -I$srcdir/build_wince -I$srcdir/build_android"